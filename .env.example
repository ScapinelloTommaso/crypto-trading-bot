# ── API Keys ──────────────────────────────────────────────────
# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# Binance Testnet (https://testnet.binance.vision/)
BINANCE_API_KEY=
BINANCE_SECRET=

# CryptoPanic (https://cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=

# ── Opzionali ─────────────────────────────────────────────────
# Modelli Groq (default: llama3-8b-8192 per sentiment, llama3-70b-8192 per strategy)
# GROQ_MODEL_FAST=llama3-8b-8192
# GROQ_MODEL_STRONG=llama3-70b-8192

# Livello di log (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
